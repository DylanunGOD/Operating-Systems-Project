# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=multimedia_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_QUEUE_KEY=jobs:queue
REDIS_PROGRESS_CHANNEL=jobs:progress

# Coordinator
COORDINATOR_HOST=coordinator
COORDINATOR_PORT=8000
COORDINATOR_WS_PATH=/ws

# Worker
WORKER_ID=${HOSTNAME}
WORKER_HEARTBEAT_INTERVAL=5
WORKER_MAX_RETRIES=3
WORKER_METRICS_PORT=9100

# Storage
MEDIA_INPUT_DIR=/media/input
MEDIA_OUTPUT_DIR=/media/output

# Observability
LOKI_URL=http://loki:3100
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Development
DEBUG=false
LOG_LEVEL=info
